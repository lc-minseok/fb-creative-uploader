# Streamlit Cloud에서는 이 값들을 Settings → Secrets UI에 동일하게 붙여넣으세요.
# 로컬에서는 이 파일을 secrets.toml 로 복사한 뒤 실제 값으로 채우세요.

GOOGLE_CLIENT_ID = "xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET = "GOCSPX-xxxx"
# Streamlit Cloud 배포 후 실제 앱 URL (끝에 슬래시 포함). 로컬은 http://localhost:8501
GOOGLE_REDIRECT_URI = "https://your-app.streamlit.app/"

FB_ACCESS_TOKEN = "EAAB..."

# 광고 계정 목록. id 는 act_ 접두사 포함.
# icon 은 public/ 폴더 기준 파일명. 비워두면 아이콘 표시 안 함.
[[ad_accounts]]
id = "act_xxxxxxxxxx"
name = "Seed Test"
icon = "seed.png"

[[ad_accounts]]
id = "act_xxxxxxxxxx"
name = "MiniTales"
icon = "minitales.png"

[[ad_accounts]]
id = "act_xxxxxxxxxx"
name = "Oh Happy Dog : Merge Story"
icon = "ohappydog.png"

[[ad_accounts]]
id = "act_xxxxxxxxxx"
name = "Legend of Slime: Idle RPG"
icon = "legendofslime.png"

[[ad_accounts]]
id = "act_xxxxxxxxxx"
name = "My Purrfect Cat Tree"
icon = "meowtower.png"
